diff --git a/src/s3e_input.c b/src/s3e_input.c
index 9ecce95..2cf5d3f 100644
--- a/src/s3e_input.c
+++ b/src/s3e_input.c
@@ -144,10 +144,12 @@ static const struct key_map KEYMAP_MELEE = KEY_MAP(KEY_MELEE);
 static const struct key_map KEYMAP_GRENADE = KEY_MAP(KEY_GRENADE);
 static const struct key_map KEYMAP_AIM = KEY_MAP(KEY_AIM);
 static const struct key_map KEYMAP_SHOOT = KEY_MAP(KEY_SHOOT);
-static const struct key_map KEYMAP_TACTICAL = KEY_MAP(KEY_TACTICAL);
-static const struct key_map KEYMAP_CROUCH = KEY_MAP(KEY_CROUCH);
-static const struct key_map KEYMAP_ALT_FIRE = KEY_MAP(KEY_ALT_FIRE);
-static const struct key_map KEYMAP_CHANGE_WEAPON = KEY_MAP(KEY_CHANGE_WEAPON);
+/* NextOS: dpad virou movimento; estes 4 (acoes do dpad) ficam sem uso.
+   Mantidos p/ referencia/futuro remapeamento, marcados unused p/ -Werror. */
+static const struct key_map KEYMAP_TACTICAL __attribute__((unused)) = KEY_MAP(KEY_TACTICAL);
+static const struct key_map KEYMAP_CROUCH __attribute__((unused)) = KEY_MAP(KEY_CROUCH);
+static const struct key_map KEYMAP_ALT_FIRE __attribute__((unused)) = KEY_MAP(KEY_ALT_FIRE);
+static const struct key_map KEYMAP_CHANGE_WEAPON __attribute__((unused)) = KEY_MAP(KEY_CHANGE_WEAPON);
 static const struct key_map KEYMAP_START = KEY_MAP(KEY_START);
 
 #undef KEY_MAP
@@ -636,18 +638,35 @@ static void input_update_game_keys(void) {
                           input_trigger(SDL_AXIS_TRIGGERRIGHT),
                       &KEYMAP_SHOOT);
     game_action_apply(input_button(SDL_BUTTON_START), &KEYMAP_START);
-    game_action_apply(input_dpad_up(), &KEYMAP_TACTICAL);
-    game_action_apply(input_dpad_down(), &KEYMAP_CROUCH);
-    game_action_apply(input_dpad_left(), &KEYMAP_ALT_FIRE);
-    game_action_apply(input_dpad_right(), &KEYMAP_CHANGE_WEAPON);
+    /* NextOS: D-pad agora e' MOVIMENTO (ver input_update_game_touchpads).
+       Handhelds dpad-only nao tem stick esquerdo -> sem isto nao ha como andar.
+       As acoes secundarias (tactical/crouch/altfire/changeweapon) sao dropadas;
+       o esquema essencial de FPS (mover/olhar/tiro/aim/recarga/melee/granada)
+       continua completo em dpad + right-stick + ABXY + L/R. */
 }
 
 static void input_update_game_touchpads(void) {
     int32_t width = XPERIA_TOUCHPAD_WIDTH;
     int32_t height = XPERIA_TOUCHPAD_HEIGHT;
     int32_t center_y = height / 2;
-    touchpad_update_stick(0, input_xperia_axis(SDL_AXIS_LEFTX), input_xperia_axis(SDL_AXIS_LEFTY),
-                          width / 5, center_y, width / 5, height / 2);
+
+    /* Movimento = stick esquerdo analogico OU D-pad (o que estiver ativo).
+       Espelha input_update_cursor(): pads dpad-only (ex.: USB Gamepad 0810:0001)
+       passam a andar; pads com stick real continuam usando o analogico. */
+    int32_t lx = input_xperia_axis(SDL_AXIS_LEFTX);
+    int32_t ly = input_xperia_axis(SDL_AXIS_LEFTY);
+    if (input_dpad_left()) {
+        lx = -32767;
+    } else if (input_dpad_right()) {
+        lx = 32767;
+    }
+    if (input_dpad_up()) {
+        ly = -32767;
+    } else if (input_dpad_down()) {
+        ly = 32767;
+    }
+
+    touchpad_update_stick(0, lx, ly, width / 5, center_y, width / 5, height / 2);
     touchpad_update_stick(1, input_xperia_axis(SDL_AXIS_RIGHTX), input_xperia_axis(SDL_AXIS_RIGHTY),
                           (width * 4) / 5, center_y, width / 8, height / 8);
 }
